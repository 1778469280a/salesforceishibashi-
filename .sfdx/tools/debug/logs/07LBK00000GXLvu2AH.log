KKSKGN,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_CE0C8801E69FA2E26E349B09856C0C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94A609C4275F50CC7C617F6CE0A409,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F7E834098FD85B1A86E77396219E2B,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_EF980BC1829E8EC05C300033CFABFC,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_7A6877EFE8D7FB90A4DA9571370642,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_D16C6D4F1B6C32B4AC53819D88043F,null,null,null,[XMLNode[TEXT,null,null,null,null,null,400,]],null,], XMLNode[ELEMENT,Resume.U_8D0C259C0AFF6CDF1806A87DC5F439,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_C4E94650CDEFC413E234DD7E6C9274,null,null,null,[XMLNode[TEXT,null,null,null,null,null,現在年収：400～449,]],null,], XMLNode[ELEMENT,Resume.U_971466A5917927863462EF570C1169,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8F8E666EE51CC8D00788940A3DC98C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_42902DED368132819B152E589AA578,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5475007220C4E3258472D5626A0563,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【PRカテゴリ】\n仕事の質に自信\n企画内容に自信\n組織運営に自信\n【PRコメント】\n・入社以来9年間、まちづくり、観光計画から緑化、自然環境\n　調査に至るまで様々な業務を担当し、企画書から業務計画\n　立案、人員・工程管理までトータルにマネージメントして\n　きました。\n・まちづくり計画においては、地域住民の参画が何よりも重要\n　との認識から、ワークショップの運営や意見交換会の開催\n　など、計画段階から住民意見を反映させるよう取り組みました。\n　特に、試行イベントやモデルツアーも企画サポートなど計画\n　のフォローアップも手がけ、単なる計画策定だけではなく\n　計画の実効性を高めるための取り組みも行ってきました。\n・コンサルタント５社協働で事業展開した地域プロジェクトでは、\n　ワーキンググループリーダーとして、研修会やミニイベント\n　企画立案から人員、予算、工程管理までを担当し、地域での\n　調整役も担いました。 \n・道路緑化計画においては、道路防雪林や事後評価に係わる\n　調査を担当し、樹木調査や土壌調査など現地調査とともに、\n　気温・雨量・土壌水分・葉温・樹幹肥大成長などの各種計測\n　機器の設置、データ回収、解析を行い、樹木の育成管理手法や\n　道路建設に伴う周辺環境の保全対策などを提案してきました。\n・また、業務で蓄積したデータを用い、日本造園学会北海道\n　支部大会に発表しました。\n・以上のような数多くの提案や地域住民とのワークショップを\n　通じて、プレゼンテーションや調整役としてのスキルを身に\n　つけることができました。\n・また、いろいろな視点から物事を考え、可能性があればトライ\n　する積極性が備わりました。\n・無資格ですが、40歳までには技術士合格を目指し、通信教育\n　講座を受講中です。\n,]],null,], XMLNode[ELEMENT,Resume.U_C80486912236BD021D1B63FFB762B4,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_12A4C297CC5D159213875DA2210BF2,null,null,null,[XMLNode[TEXT,null,null,null,null,null,資格：運転免許・理美容・その他系/普通自動車免許（第一種）\nキャリア：建築・土木・不動産関連職/経験業務/企画・設計系/土木設計/実務1-3年\n建築・土木・不動産関連職/経験業務/積算・資材・その他/積算/実務1-3年\n\nITスキル：OS /PC系/Windows2000Professional/実務5- 年\nOS /PC系/Windows95/98/実務3-5年\nOS /PC系/WindowsMe/XP/実務3-5年\nPC基本ソフト/MS/Access/実務1-3年\nPC基本ソフト/MS/Excel/実務5- 年\nPC基本ソフト/MS/PowerPoint/実務5- 年\nPC基本ソフト/MS/Word/実務5- 年\nPC基本ソフト/グラフィック・DTP関連/Illustrator/実務1-3年\nPC基本ソフト/グラフィック・DTP関連/Photoshop/実務1-3年,]],null,], XMLNode[ELEMENT,Resume.U_ADE568278037E18C20F3AF78AAF8A8,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【語学レベル】\n\n【海外赴任】,]],null,], XMLNode[ELEMENT,Resume.U_90AD127E5FCEBCD1AF01DDC8295708,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F205EBF7F6A862C6A9E8DDB135F797,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94E831023512892988CDD4FC4987EB,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_13C45F7FFAFC1AB430E6038C76125A,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5F7FC5144BA471117A376B60BC8D90,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8E20986D8967D107BEE5D63870AD68,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_DDF5A119155AD1F559BAA37C031C4E,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_GCLID,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_B41102CD1A612DA93AA74B5462DE6E,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8B5178364C17E24A72A2113296D4A5,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_9B5DE90D67C3C57A12D66F84AFA05F,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_ACB4CAC6E89348FD55DF19E6E20155,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8EF0F79E169EAD365B63D86C9C80B8,null,null,null,null,null,]],null,], XMLNode[ELEMENT,Item,null,null,null,[XMLNode[ELEMENT,Resume.P_RegisterChannel,null,null,null,[XMLNode[ELEMENT,Option.U_000678,null,null,null,[XMLNode[ELEMENT,Option.P_Name,null,null,null,[XMLNode[TEXT,null,null,null,null,null,イーキャリアFA,]],null,], XMLNode[ELEMENT,Option.P_Id,null,null,null,[XMLNode[TEXT,null,null,null,null,null,10678,]],null,]],null,]],null,], XMLNode[ELEMENT,Resume.P_Id,null,null,null,[XMLNode[TEXT,null,null,null,null,null,15054,]],null,], XMLNode[ELEMENT,Resume.P_DateOfBirth,null,null,null,null,null,], XMLNode[ELEMENT,Resume.P_Gender,null,null,null,[XMLNode[ELEMENT,Option.P_Male,null,null,null,[XMLNode[ELEMENT,Option.P_Name,null,null,null,[XMLNode[TEXT,null,null,null,null,null,男性,]],null,], XMLNode[ELEMENT,Option.P_Id,null,null,null,[XMLNode[TEXT,null,null,null,null,null,52,]],null,]],null,]],null,], XMLNode[ELEMENT,Resume.P_Phase,null,null,null,null,null,], XMLNode[ELEMENT,Resume.P_PhaseDate,null,null,null,null,null,], XMLNode[ELEMENT,Resume.P_Education,null,null,null,[XMLNode[TEXT,null,null,null,null,null,\n　　　\n[期間]/～/[卒業ステータス][学歴区分]大学[文理区分]文系[学校名/学部名/学科名]茨城大学　教育学部　　進路指導科[学歴メモ]最終前卒業校：北海道立　釧路湖陵　高等学校,]],null,], XMLNode[ELEMENT,Resume.P_CurrentStatus,null,null,null,[XMLNode[ELEMENT,Option.P_Working,null,null,null,[XMLNode[ELEMENT,Option.P_Name,null,null,null,[XMLNode[TEXT,null,null,null,null,null,就業中,]],null,], XMLNode[ELEMENT,Option.P_Id,null,null,null,[XMLNode[TEXT,null,null,null,null,null,60,]],null,]],null,]],null,], XMLNode[ELEMENT,Resume.P_ChangeJobsCount,null,null,null,null,null,], XMLNode[ELEMENT,Resume.P_CurrentSalary,null,null,null,[XMLNode[TEXT,null,null,null,null,null,500,]],null,], XMLNode[ELEMENT,Resume.P_CarrierSummary,null,null,null,[XMLNode[TEXT,null,null,null,null,null,[期間]/～/[会社名][部署名][役職名][事業内容][従業員数][雇用形態]正社員[担当職務][備考]\n【経験職種】\nクリエイティブ関連/デザイン関連職/アートディレクター・クリエイティブディレクター\nクリエイティブ関連/WEB関連職/コンテンツ企画・編集\nクリエイティブ関連/制作・編集・印刷関連職/制作\nクリエイティブ関連/映像・イベント関連職/プロデューサー・ディレクター（放送・イベント）\nクリエイティブ関連/映像・イベント関連職/アシスタントディレクター（放送・イベント）\nクリエイティブ関連/映像・イベント関連職/映像専門職(撮影・編集・加工)\nクリエイティブ関連/映像・イベント関連職/コーディネータ・手配業務\nクリエイティブ関連/映像・イベント関連職/進行管理\nクリエイティブ関連/映像・イベント関連職/制作専門職\nクリエイティブ関連/映像・イベント関連職/その他放送・イベント関連職\n\n【経験業種】\nマスコミ系/放送・映像\nマスコミ系/広告・制作\nマスコミ系/音楽・芸能\nＩＴ・通信系/インターネット関連\nＩＴ・通信系/その他IT関連\n\n【職務経歴】\n【職歴】\n●2000年10月～現職　　　　　　株式会社ウェザーニューズ（正社員）\n●1997年9月～2000年9月（日本撤退）株式会社クロステレビ（正社員）\n●1990年4月～1997年8月（会社倒産）有限会社HAC-CHANNEL2（契約社員）\n\n******************************************************************\n◆職歴１\n企業名：株式会社ウェザーニューズ\n在職期間：2000年10月～現職\n事業内容：【気象情報会社】気象、環境に関わる情報、コンテンツの発信。WEB、MOBILE、放送等のメディアを有す。\n従業員数:722\n勤務地：千葉県　\n雇用形態：正社員\n******************************************************************\n【職務内容】\n・コンテンツ（番組）ディレクター\n・テクニカルディレクター\n\n【職務概要】\n気象情報会社において、自社放送の番組制作・運用に携わっています。担当メディアは、スカイ・パーフェクTV、全国CATV、BSデジタル・データ放送など。現在はTV放送だけではなく、インターネット（ブロードバンド）やモバイルへの動画コンテンツ配信プロジェクトのリーダーも担当しています。このプロジェクトにおいては、ハードウェア的には制作・編集・配信までをトータルに行うことができるシステムの構築と運用の確立を行い、コンテンツの制作では、番組の制作ディレクションを手がけています。\n\n【即戦力となる知識・スキル】\n・番組、CM、スポット制作\n・動画制作／編集／配信等インフラ構築・運用\n・放送システムの設計／構築／運用\n・生放送のテクニカルディレクション\n・音楽コンテンツ制作ディレクション\n\n【マネジメント経験】\nコンテンツ運用カンパニー／動画制作セクションのセクション・リーダーとして、12名のマネジメントを行っています。業務の流れを「自分一人でやる、やり遂げる」→「仲間と一緒に達成する」という、点から面への流れに意識を変化させることにより、チーム全体のモチベーションの向上を目指しています。これにより、目標と達成感のバランスが改善され、20代を中心とした若手のスタッフの中で連帯感が強くなったと思います。結果的に、コンテンツの充実を図ることができていると思います。\n\n【所属・担当歴】\n■2000年10月　入社　コンテンツ運用カンパニー／\n動画制作セクションに配属\n自社放送テクニカルディレクター（運用技術リーダー）\n■2000年12月　自社放送音楽コンテンツ制作セクションを発足させる\n（プロデューサー、制作ディレクター、自社放送TDを兼務）\n■2001年 6月  自社放送用CMの制作ディレクターとなる\n（自社放送TDを兼務）　 \n■2003年 1月　海外向け動画配信プロジェクトに参加（技術リーダー）\nノンリニア編集システム、配信システムなどの構築を手がける\n■2003年 3月　新放送送出システム構築プロジェクトを発足\n（プロデューサー）海外資産の転用プロジェクトのリーダーを兼務\n■2004年10月　ブロードバンド、モバイルへの動画配信プロジェクトに参加（インフラ構築リーダー、コンテンツディレクターを兼務）\n\n【担当メディア】\nスカイパーフェクTV、全国CATV、BSデジタル・データ放送、インターネット（BIGLOBE、日経BB等）、モバイル（EZ-web、韓国KTF、docomo等）\n\n【業務内容】\n（１）自社放送のテクニカル・ディレクション業務の統括\n・自社放送のテクニカル・ディレクション（生放送運用等）\n・放送システムの設計／構築／管理（マスターシステム、\n  サブシステム等）\n・スタッフ・マネジメント（アウトソース管理）\n\n（２）番組制作コンテンツ・ディレクション\n・自社放送の番組ディレクション（気象番組、防災番組）\n・自社放送内CMやスポット、フィラー等の制作ディレクション\n\n（３）動画コンテンツ配信プロジェクトの企画・実施\n・海外TVメディア（マレーシア）向けのMPG2での動画配信\n  プロジェクトにおけるインフラの構築と制作フローの確立\n・MXTV（東京メトロポリタン）への動画配信プロジェクトにおける\n  インフラの構築と制作フローの確立\n・ブロードバンド放送やモバイルへの動画番組配信プロジェクトに\n  おけるインフラの構築とシステムの運用\n\n（４）自社放送システムの構築\n・自社放送マスター（送出）システムの新規構築\n\n【制作実績】\n■自社放送天気番組\n【概要】毎日の気象情報番組（生放送、収録）\n【メディア】スカイパーフェクTV、全国CATV、BSデジタルデータ放送\n【制作期間】2000年10月～現在\n【担当業務】テクニカル・ディレクション（放送運用）、\n コンテンツ制作ディレクション（企画／制作）\n【運用形態】チーム全体5名～12名（24時間のシフト制）\n\n■国内向け動画配信\n【概要】国内TV局、インターネット、モバイルへの動画気象番組の\n 配信\n【メディア】インターネット（日経BB、BIGLOBE）モバイル\n（EZ-web、docomo）地上波TV（東京メトロポリタンテレビ \n 2004年10月 ～2005年3月）\n【制作期間】2003年12月～現在\n【担当業務】インフラ構築、番組制作フロー\n（収録／編集／配信）の 確立テクニカルディレクション\n【運用形態】５人\n【成果】自社での完パケをまるごと配信することにより、制作に\n かかるコストを大幅に削減することができた。また、他のメディア\n にもコンテンツを流用させることにより、一番組にかかる制作\n コストの削減につながった。\n \n■海外向け動画配信プロジェクト\n【概要】マレーシア国営放送（RTM）への動画による気象情報番組\n の配信\n【メディア】Radio Television Malaysia\n【制作期間】RTM案件＝2003年1月～2004年8月 \n【担当業務】インフラ構築、番組制作フロー（収録／編集／配信）\n の確立及びテクニカルディレクション\n【運用形態】RTM=マレーシア人アルバイトを含む5人（毎日）\n【成果】グローバルな視点での動画コンテンツ配信の第一歩を\n 踏み出すことができた\n\n■新放送送出システムの設計／構築と海外資産転用\n【概要】自社放送システム（送出マスターシステム）の新規構築と\n 海外資産転用による経費削減プロジェクトの発足と実施\n【制作期間】2003年3月～2003年12月\n【担当業務】プロデューサー\n【成果】およそ２億円の経費削減を達成できた\n\n\n\n******************************************************************\n◆職歴２\n企業名：株式会社クロステレビ\n在職期間：1997年9月～2000年9月（日本撤退）\n事業内容：【放送業務請負】番組制作、放送業務、設備／機材等の提案等\n従業員数:700\n勤務地：東京都／茨城県　\n雇用形態：正社員\n******************************************************************\n【経験職種】\n・放送局開局プロジェクトメンバー\n・映像制作／編集（編集技術職）\n\n【職務概要】\nCSデジタル放送（ディレク・ティービー）の開局プロジェクトに参加。放送送出センターにて、映像制作／編集システムの立ち上げ、及び運用フローの確立、スタッフへの運用指導を行い、開局後は、映像制作・編集、テクニカル・ディレクションなど技術職として業務に従事しました。2000年9月、ディレク・ティービーは日本を撤退しました。\n\n【所属歴】\n1997年9月　入社　マルチメディア事業部配属。\n株式会社ディレクティービージャパン放送センターへ出向。制作課所属。\n　\n【業務内容】\n（１）ディレクティービー開局プロジェクトへの参加。放送センターに\n おける放送素材の制作・編集システムの最終調整と運用フローの確立\n（２）運用マニュアルの翻訳、スタッフへの技術指導\n（３）放送素材の制作・編集\n（４）音声編集システムの設計／構築／運用\n（５）放送素材のクオリティアセスメント\n\n【業務実績】\n■開局プロジェクト\n【概要】ディレクティービー放送送出センター（茨城県）にて、映像素材の 制作・編集するためのシステムの最終調整と運用技術の確立を行いました。続いて、アメリカ本国の運用フロー、ハードウェア／ソフトウェアの運用技術を日本語訳し、運用スタッフへの技術指導までを担当しました。\n【担当期間】1997年9月～1997年12月\n【成果】放送局の誕生を一から経験できたことと、外国の運用技術を日本の それに合うよう、スタッフ全員で努力し、フローを確立できたことです。\n\n■映像制作・編集\n【概要】プロモーションチャンネルで使用されるスポット素材の制作、各番組供給会社から送られてくる放送素材の編集／加工／修正を主に手掛けていました。制作ディレクターから提示される素材、制作フロー、スクリプトを編集し、イメージを具現化させることが中心となる技術的な業務を担当していました。その他に、外部イベントにおけるディレクテーィービーＣＭなどの制作を担当しました。これについては、制作ディレクションから全てをチームメンバーで担当し、持ち回りでコンテンツ制作にあたりました。\n【担当期間】1997年12月～2000年9月\n【成果】フルデジタルのリニア及びノンリニア編集システムを、運用の確立から手掛けられたことと、単なる技術職だけに止まらないクリエイティヴな制作までを担当することができたことです。\n\n■音声編集システムの設計／構築／運用（プロジェクト・リーダー）\n【概要】外部制作プロダクションでの制作費を削減するため、社内での音声編集をする環境の構築がプロジェクト化されました。その中で、プロジェクトリーダーとしてシステムの設計／構築／運用指導までを担当しました。\n【担当期間】1999年4月～1999年7月\n【成果】その当時、最先端のPro Toolsを核とする音声編集システムの構築を手掛けることができました。これにより、映像素材の外部プロダクションでの制作費を削減することができました。\n\n\n\n******************************************************************\n◆職歴３\n企業名：有限会社HAC-CHANNEL2\n在職期間：1990年4月～1997年8月（会社倒産）\n事業内容：【映像制作会社】CM制作、番組制作、放送業務請負、\nブライダル事業等\n従業員数:15\n勤務地：東京都　\n雇用形態：契約社員\n******************************************************************\n【経験職種】\n・映像制作／編集（技術職）\n・ブライダル事業（撮影／編集／スタッフマネジメント）\n\n【職務概要】\n映像制作（CM、VP、プロモーションなど）を主に行いました。1992年より、新規ブライダル事業に参加。システムの立ち上げと運用フローの確立を行いました。現場では撮影／編集オペレーター主任を務めました。\n\n【所属歴】\n1990年4月　入社　本社映像制作室配属\n1992年10月　ホテル海洋映像調整室へ出向（運用技術主任）\n\n【業務内容】\n（１）映像制作／編集\n（２）ブライダル撮影／編集\n\n【業務実績】\n■映像制作／編集\n【概要】本社にてCMの制作／編集、ミュージックプロモーションの制作／編集を主に行っていました。担当は株式会社オートバックス、キングレコード株式会社。\n【担当期間】1990年4月～1992年9月\n【成果】映像制作／編集の基本を身に付けることができました。また、放送用ハードのアナログからデジタルへの移行を、身近に体験することができました。\n\n■ブライダル撮影／編集\n【概要】社の新規プロジェクト（ブライダル）に参加し、運用技術主任としてブライダルホテルの映像調整室に出向しました。結婚式の撮影、編集までを行い、運用する際のアルバイトへの技術指導、管理も行いました。\n【担当期間】1992年10月～1997年8月\n【成果】顧客にとっては一生に一度のイベントを手掛けるプレッシャーと、仕事をやり終えた後の充実感を身をもって体験することができました。また、社にとっての新規事業のオープニングスタッフとして貢献できたこともとても良い経験になったと思います。,]],null,], XMLNode[ELEMENT,Resume.U_4519E06428F3E45FB1C14E878185BE,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_45A05CBAF79D5527F38A6F59E1243B,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_E49E1480A206956CDD882F6A2063E7,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_AC5A0D55E86D3363238C61F123390E,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_LASTLOGIN,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_91DBD8B96BAAD6B33B538CF2494377,null,null,null,[XMLNode[TEXT,null,null,null,null,null,ヨシダ タダタカ