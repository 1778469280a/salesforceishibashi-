169,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8F8E666EE51CC8D00788940A3DC98C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_42902DED368132819B152E589AA578,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5475007220C4E3258472D5626A0563,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【PRカテゴリ】\n仕事の質に自信\n企画内容に自信\n営業力・提案力に自信\n【PRコメント】\n　大学卒業後、専攻した建築工学を生かそうと、県内大手建設会社に入社し、現場監理を７年経験しました。円満退社後、時代の流れがカタログなどの通信販売にあると感じ、カタログ販売商社に入社しました。そこで、商品企画から撮影、カタログ編集と多くの経験を積みました。事情により、やむなく退社後、撮影経験を生かし\n写真業界に転職しました。このような経験を是非生かしたく、また、地元で築いてきた人脈なども、是非御社のお力になれるのではないかと思っております。\n　宜しくお願い申し上げます。\n,]],null,], XMLNode[ELEMENT,Resume.U_C80486912236BD021D1B63FFB762B4,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_12A4C297CC5D159213875DA2210BF2,null,null,null,[XMLNode[TEXT,null,null,null,null,null,資格：土木・建築・不動産系/2級建築士\n運転免許・理美容・その他系/普通自動車免許（第一種）\n運転免許・理美容・その他系/普通二輪免許\nキャリア：建築・土木・不動産関連職/経験業務/企画・設計系/建築設計(意匠)/実務1-3年\n建築・土木・不動産関連職/経験業務/企画・設計系/製図/実務5- 年\n建築・土木・不動産関連職/経験業務/積算・資材・その他/積算/実務1-3年\n建築・土木・不動産関連職/経験業務/積算・資材・その他/資材手配・管理/実務3-5年\n建築・土木・不動産関連職/経験業務/施工管理・設備工事系/施工管理/実務5- 年\n建築・土木・不動産関連職/経験分野/住宅関連/戸建て(木造)/実務1-3年\n建築・土木・不動産関連職/経験分野/大型施設関連/小型商業施設/実務1-3年\n営業関連職/経験業務(営業系)/営業系/営業・企画営業(法人向け)/実務3-5年\n営業関連職/経験業務(営業系)/営業系/営業・企画営業(個人向け)/実務1-3年\n営業関連職/経験業務(営業系)/営業系/ルートセールス/実務5- 年\n営業関連職/経験業務(営業系)/営業系/内勤営業・カウンターセールス/実務1-3年\n営業関連職/経験業務(営業系)/その他営業系/外商/実務 -1年\n営業関連職/経験業務(営業系)/その他営業系/顧客管理/実務1-3年\n営業関連職/取扱商品分野/インテリア・雑貨　/雑貨・小物/実務1-3年\n営業関連職/取扱商品分野/広告・出版・イベント・ゲーム/広告/実務1-3年\n営業関連職/取扱商品分野/サービス/ブライダル関連/実務1-3年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/コーディネーター・手配業務/実務1-3年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(デザイン系)/経験業務/アートディレクター/実務 -1年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/編集/実務1-3年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/制作デスク・進行管理/実務1-3年\n\nITスキル：,]],null,], XMLNode[ELEMENT,Resume.U_ADE568278037E18C20F3AF78AAF8A8,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【語学レベル】\n\n【海外赴任】,]],null,], XMLNode[ELEMENT,Resume.U_90AD127E5FCEBCD1AF01DDC8295708,null,null,null,null,null,], XMLNode[ELEMENT,Resum