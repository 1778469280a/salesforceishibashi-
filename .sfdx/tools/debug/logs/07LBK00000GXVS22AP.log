e.U_C4E94650CDEFC413E234DD7E6C9274,null,null,null,[XMLNode[TEXT,null,null,null,null,null,現在年収：300～349,]],null,], XMLNode[ELEMENT,Resume.U_971466A5917927863462EF570C1169,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8F8E666EE51CC8D00788940A3DC98C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_42902DED368132819B152E589AA578,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5475007220C4E3258472D5626A0563,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【PRカテゴリ】\n\n【PRコメント】\n　通研電気工業株式会社では、入社後、営業管理業務を担当し、八年目から東北電力という特定のお客様ではありましたが、営業を経験することによって、営業ノウハウを磨くとともに、お客様に喜んでいただけたときの充実感は、なにものにも代え難いものであることを実感いたしました。\n　また、東日システム株式会社では、官公庁、病院などへの営業を含め、老健施設などへの飛込セールスも経験し、目標を達成する喜びを知りました。\n　現在、在職中の明治宅配センター仙台北支店では、一般家庭への営業の開拓業務を自らも実施し、営業開拓スタッフ及び配達スタッフの管理業務や商品の在庫、発注管理などセンター内全の全ての業務を管理しております。\n　積極的に人と関わることを好み、努力を惜しまない粘り強い一面もありますので、業務の支えとなれるよう、今までのキャリアを生かし仕事に取り組んで生きたいと思います。\n,]],null,], XMLNode[ELEMENT,Resume.U_C80486912236BD021D1B63FFB762B4,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_12A4C297CC5D159213875DA2210BF2,null,null,null,[XMLNode[TEXT,null,null,null,null,null,資格：\nキャリア：営業関連職/経験業務(営業系)/営業系/営業・企画営業(法人向け)/実務1-3年\n営業関連職/経験業務(営業系)/営業系/営業・企画営業(個人向け)/実務 -1年\n営業関連職/経験業務(営業系)/営業系/営業マネジャー・営業管理/実務 -1年\n営業関連職/経験業務(営業系)/その他営業系/顧客管理/実務 -1年\n営業関連職/経験業務(営業系)/その他営業系/営業事務/実務5- 年\n事務・企画・経営関連職/経験業務(財務・会計・経理系)/財務・会計・経理関連業務/決算関連実務/実務5- 年\n\nITスキル：OS /PC系/Windows95/98/実務5- 年\nOS /PC系/WindowsMe/XP/実務3-5年\nPC基本ソフト/MS/Excel/実務5- 年\nPC基本ソフト/MS/PowerPoint/実務5- 年\nPC基本ソフト/MS/Word/実務5- 年,]],null,], XMLNode[ELEMENT,Resume.U_ADE568278037E18C20F3AF78AAF8A8,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【語学レベル】\n\n【海外赴任】,]],null,], XMLNode[ELEMENT,Resume.U_90AD127E5FCEBCD1AF01DDC8295708,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F205EBF7F6A862C6A9E8DDB135F797,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94E831023512892988CDD4FC4987EB,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_13C45F7FFAFC1AB430E6038C76125A,null,null,null,null,null,], XMLNode[ELEMENT,