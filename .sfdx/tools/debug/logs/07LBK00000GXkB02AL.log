de[ELEMENT,Resume.U_AGETNTSUSAGE,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_4495E00E8A888DDC61CF3A56D104F8,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_80F76B1B3D339C9387773F1C457E51,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_KKSKGN,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_CE0C8801E69FA2E26E349B09856C0C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94A609C4275F50CC7C617F6CE0A409,null,null,null,[XMLNode[TEXT,null,null,null,null,null,2005/10/01,]],null,], XMLNode[ELEMENT,Resume.U_F7E834098FD85B1A86E77396219E2B,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_EF980BC1829E8EC05C300033CFABFC,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_7A6877EFE8D7FB90A4DA9571370642,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_D16C6D4F1B6C32B4AC53819D88043F,null,null,null,[XMLNode[TEXT,null,null,null,null,null,500,]],null,], XMLNode[ELEMENT,Resume.U_8D0C259C0AFF6CDF1806A87DC5F439,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_C4E94650CDEFC413E234DD7E6C9274,null,null,null,[XMLNode[TEXT,null,null,null,null,null,現在年収：500～549,]],null,], XMLNode[ELEMENT,Resume.U_971466A5917927863462EF570C1169,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8F8E666EE51CC8D00788940A3DC98C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_42902DED368132819B152E589AA578,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5475007220C4E3258472D5626A0563,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【PRカテゴリ】\n仕事の質に自信\n組織運営に自信\n業務関連スキルに自信\n【PRコメント】\n常に新しいメディアとコンテンツ配信の在り方を考えています。地上デジタル放送、ブロードバンド放送、移動体通信などのデジタル・メディアやインフラを利用しつつ、今までにない動画コンテンツ配信サービスを確立していきたいと考えています。自分自身の「届けたい」＝「人の役に立つ」の関係性を目標のゴールとし、レスポンスが直接届くようなビジネスにまで持っていきたいと思うのです。例えば、地域密着型の防災のツールとして、介護・福祉のツールとして、或いは、教育全般のツールとして、エンターテイメントだけに止まらない、より生活に密着した形でのコンテンツ提供にまで広げていくことが目標です。その目標を達成する歩みの中で、自らが今までに得てきた、放送業界でのソフト制作技術（番組制作やサービスの立ち上げなど）とハード構築・運用技術、両方のスキルは武器となるのではないかと考えています。また、新規事業に身を置くことで、自らのチャレンジャブルな部分を刺激しつつモチベーションを上げていくことが得意なため、今後もメディアの融合や新しい利用の仕方を考えつつ、新しい動画コンテンツ配信ビジネスを確立していきたいと考えています。\n,]],null,], XMLNode[ELEMENT,Resume.U_C80486912236BD021D1B63FFB762B4,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_12A4C297CC5D159213875DA2210BF2,null,null,null,[XMLNode[TEXT,null,null,null,null,null,資格：教育・語学系/教諭（小学校）\n教育・語学系/教諭（中学校）\n教育・語学系/教諭（高等学校）\n運転免許・理美容・その他系/普通自動車免許（第一種）\nキャリア：インターネット関連職/経験業務/コンテンツ系/Webコンテンツ制作/実務1-3年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/プロデューサー(映像)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/ディレクター(映像)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/ディレクター(音響)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/映像制作(撮影)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/編集(映像)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/編集(音響)/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験業務/その他映像・イベント関連職/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験分野/テレビ番組/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験分野/CF/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験分野/ビデオ/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験分野/スポーツイベント/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(映像・イベント系)/経験分野/結婚式・ブライダル関連/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/企画制作ディレクター/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/編集/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/制作/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(編集・制作・印刷系)/経験業務/制作デスク・進行管理/実務5- 年\nクリエイティブ・マスコミ・ゲーム関連職/経験業務(音楽・芸能)/経験業務/作曲・編曲/実務5- 年\n\nITスキル：OS /PC系/MacOS/実務3-5年\nOS /PC系/WindowsNT/実務3-5年\nOS /PC系/Windows2000Professional/実務1-3年\nOS /PC系/Windows2000Serverシリーズ/実務1-3年\nOS /PC系/Windows95/98/実務1-3年\nOS /PC系/WindowsMe/XP/実務1-3年\nPC基本ソフト/MS/Excel/実務5- 年\nPC基本ソフト/MS/PowerPoint/実務5- 年\nPC基本ソフト/MS/Word/実務5- 年\nPC基本ソフト/グラフィック・DTP関連/Illustrator/実務5- 年\nPC基本ソフト/グラフィック・DTP関連/Photoshop/実務5- 年,]],null,], XMLNode[ELEMENT,Resume.U_ADE568278037E18C20F3AF78AAF8A8,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【語学レベル】\n英語/文書読解/実務5- 年\n英語/メール交換/実務5- 年\n【海外赴任】,]],null,], XMLNode[ELEMENT,Resume.U_90AD127E5FCEBCD1AF01DDC8295708,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F205EBF7F6A862C6A9E8DDB135F797,null,null,null,null,null,], XML