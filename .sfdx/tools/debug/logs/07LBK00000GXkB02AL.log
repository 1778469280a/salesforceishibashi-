l,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94A609C4275F50CC7C617F6CE0A409,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F7E834098FD85B1A86E77396219E2B,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_EF980BC1829E8EC05C300033CFABFC,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_7A6877EFE8D7FB90A4DA9571370642,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_D16C6D4F1B6C32B4AC53819D88043F,null,null,null,[XMLNode[TEXT,null,null,null,null,null,400,]],null,], XMLNode[ELEMENT,Resume.U_8D0C259C0AFF6CDF1806A87DC5F439,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_C4E94650CDEFC413E234DD7E6C9274,null,null,null,[XMLNode[TEXT,null,null,null,null,null,現在年収：400～449,]],null,], XMLNode[ELEMENT,Resume.U_971466A5917927863462EF570C1169,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8F8E666EE51CC8D00788940A3DC98C,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_42902DED368132819B152E589AA578,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5475007220C4E3258472D5626A0563,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【PRカテゴリ】\n仕事の質に自信\n企画内容に自信\n組織運営に自信\n【PRコメント】\n・入社以来9年間、まちづくり、観光計画から緑化、自然環境\n　調査に至るまで様々な業務を担当し、企画書から業務計画\n　立案、人員・工程管理までトータルにマネージメントして\n　きました。\n・まちづくり計画においては、地域住民の参画が何よりも重要\n　との認識から、ワークショップの運営や意見交換会の開催\n　など、計画段階から住民意見を反映させるよう取り組みました。\n　特に、試行イベントやモデルツアーも企画サポートなど計画\n　のフォローアップも手がけ、単なる計画策定だけではなく\n　計画の実効性を高めるための取り組みも行ってきました。\n・コンサルタント５社協働で事業展開した地域プロジェクトでは、\n　ワーキンググループリーダーとして、研修会やミニイベント\n　企画立案から人員、予算、工程管理までを担当し、地域での\n　調整役も担いました。 \n・道路緑化計画においては、道路防雪林や事後評価に係わる\n　調査を担当し、樹木調査や土壌調査など現地調査とともに、\n　気温・雨量・土壌水分・葉温・樹幹肥大成長などの各種計測\n　機器の設置、データ回収、解析を行い、樹木の育成管理手法や\n　道路建設に伴う周辺環境の保全対策などを提案してきました。\n・また、業務で蓄積したデータを用い、日本造園学会北海道\n　支部大会に発表しました。\n・以上のような数多くの提案や地域住民とのワークショップを\n　通じて、プレゼンテーションや調整役としてのスキルを身に\n　つけることができました。\n・また、いろいろな視点から物事を考え、可能性があればトライ\n　する積極性が備わりました。\n・無資格ですが、40歳までには技術士合格を目指し、通信教育\n　講座を受講中です。\n,]],null,], XMLNode[ELEMENT,Resume.U_C80486912236BD021D1B63FFB762B4,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_12A4C297CC5D159213875DA2210BF2,null,null,null,[XMLNode[TEXT,null,null,null,null,null,資格：運転免許・理美容・その他系/普通自動車免許（第一種）\nキャリア：建築・土木・不動産関連職/経験業務/企画・設計系/土木設計/実務1-3年\n建築・土木・不動産関連職/経験業務/積算・資材・その他/積算/実務1-3年\n\nITスキル：OS /PC系/Windows2000Professional/実務5- 年\nOS /PC系/Windows95/98/実務3-5年\nOS /PC系/WindowsMe/XP/実務3-5年\nPC基本ソフト/MS/Access/実務1-3年\nPC基本ソフト/MS/Excel/実務5- 年\nPC基本ソフト/MS/PowerPoint/実務5- 年\nPC基本ソフト/MS/Word/実務5- 年\nPC基本ソフト/グラフィック・DTP関連/Illustrator/実務1-3年\nPC基本ソフト/グラフィック・DTP関連/Photoshop/実務1-3年,]],null,], XMLNode[ELEMENT,Resume.U_ADE568278037E18C20F3AF78AAF8A8,null,null,null,[XMLNode[TEXT,null,null,null,null,null,【語学レベル】\n\n【海外赴任】,]],null,], XMLNode[ELEMENT,Resume.U_90AD127E5FCEBCD1AF01DDC8295708,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_F205EBF7F6A862C6A9E8DDB135F797,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_94E831023512892988CDD4FC4987EB,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_13C45F7FFAFC1AB430E6038C76125A,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_5F7FC5144BA471117A376B60BC8D90,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8E20986D8967D107BEE5D63870AD68,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_DDF5A119155AD1F559BAA37C031C4E,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_GCLID,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_B41102CD1A612DA93AA74B5462DE6E,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8B5178364C17E24A72A2113296D4A5,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_9B5DE90D67C3C57A12D66F84AFA05F,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_ACB4CAC6E89348FD55DF19E6E20155,null,null,null,null,null,], XMLNode[ELEMENT,Resume.U_8EF0F79E169EAD365B63D86C9C80B8,null,null,null,null,null,]],null,]"|0x272ae03d
