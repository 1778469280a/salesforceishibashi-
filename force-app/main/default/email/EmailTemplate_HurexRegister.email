<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background:#FFFFFF; font-family: Arial, Helvetica, sans-serif;">
  <!-- 整体容器：最大宽度700px，水平垂直居中在大屏，手机自适应宽度 -->
  <table width="100%" height="100%" cellpadding="0" cellspacing="0" border="0" align="center" style="min-height:100vh;">
    <tr>
      <td align="center" valign="middle" style="padding:0;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0" align="center" style="max-width:700px; width:100%;">
          <!-- 主标题 -->
          <tr>
            <td style="padding:60px 20px 24px; text-align:center;">
              <div style="font-size:32px; font-weight:700; color:#333333; line-height:1.5; text-align:center;">
                ご登録のメールアドレスに、<br/>メールをお送りしました。1111111111111111
              </div>
            </td>
          </tr>
          <!-- 副标题 -->
          <tr>
            <td style="padding:0 20px 32px; text-align:center;">
              <div style="font-size:20px; color:#666666; font-weight:normal; line-height:1.6; text-align:center;">
                メールに記載のリンクをクリックし、<br/>追加情報登録へお進みください。
              </div>
            </td>
          </tr>
          <!-- 提示框 -->
          <tr>
            <td style="padding:0 20px 40px; text-align:center;">
              <table width="420" cellpadding="0" cellspacing="0" border="0" style="border:2px solid #333333; border-radius:8px; background:#FFFFFF; margin:0 auto; text-align:center; width:100%; max-width:450px;">
                <tr>
                  <td style="padding:24px 32px; font-size:18px; color:#333333; line-height:1.8; font-family: Arial, sans-serif; text-align:center;">
                    メールが届かない場合は、お手数ですが<br/>
                    迷惑メールフォルダをご確認いただくか<br/>
                    ご登録アドレスに誤りがないかお確かめのうえ<br/>
                    再度メールアドレス認証をお試しください。
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- 按钮 -->
          <tr>
            <td style="padding:0 0 60px; text-align:center;">
              <a href="{{{rootUrl}}}" target="_blank" style="display:inline-block; min-width:240px; height:56px; padding:0 48px; background:#2B5797; color:#ffffff; text-decoration:none; border-radius:8px; font-size:20px; font-weight:700; line-height:56px;">
                トップページへ戻る ▷
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
